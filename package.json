{
  "name": "kindle-ai-export",
  "private": true,
  "version": "0.1.0",
  "description": "Export any Kindle book you own as text, PDF, EPUB, or as a custom, AI-narrated audiobook.",
  "author": "Travis Fischer <travis@transitivebullsh.it>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/transitive-bullshit/kindle-ai-export.git"
  },
  "packageManager": "pnpm@9.11.0",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "check": "pnpm run format-check && pnpm run lint && pnpm run unit",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,ts,tsx,md,json,yml,yaml}\"",
    "format-check": "prettier --check \"**/*.{js,ts,tsx,md,json,yml,yaml}\"",
    "unit": "tsc --noEmit",
    "test": "pnpm run check",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "dotenv": "^17.4.1",
    "globby": "^16.2.0",
    "hash-object": "^5.1.0",
    "kindle-api-ky": "^1.0.1",
    "ky": "^2.0.0",
    "node-id3": "^0.2.9",
    "openai-fetch": "^3.4.2",
    "p-map": "^7.0.4",
    "pdfkit": "^0.18.0",
    "playwright": "^1.59.1",
    "playwright-core": "^1.59.1",
    "unrealspeech-api": "^1.0.2"
  },
  "devDependencies": {
    "@fisch0920/eslint-config": "^1.4.0",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^25.6.0",
    "@types/pdfkit": "^0.17.5",
    "delay": "^7.0.0",
    "eslint": "^8.57.0",
    "only-allow": "^1.2.2",
    "prettier": "^3.8.2",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
